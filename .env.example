# Required
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-secret
OPENCLAW_VERSION=2026.6.10
NODE_IMAGE=node:24-bookworm-slim
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.6
BROWSER_IMAGE=coollabsio/openclaw-browser:0.3.0

# Required Open WebUI bootstrap credentials and persistent signing key
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=change-me-to-a-random-password
WEBUI_ADMIN_NAME=Admin
WEBUI_SECRET_KEY=change-me-to-a-random-secret
WEBUI_JWT_EXPIRES_IN=24h

# Optional OpenClaw credentials
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Optional runtime configuration
OPENCLAW_GATEWAY_PORT=18789
OPEN_WEBUI_PORT=8080
OPENCLAW_TZ=UTC
OLLAMA_API_KEY=ollama-local
OLLAMA_BASE_URL=http://host.docker.internal:11434
LOCAL_OWNER=johnt
LOCAL_GROUP=staff
LOCAL_UID=
LOCAL_GID=
