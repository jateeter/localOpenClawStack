        "id": "acp-communitycommandagent-input-assessment",
        "sensorId": "acp.openclaw.communitycommandagent.input-analyst.assessment",
        "name": "OpenClaw communitycommandagent input-analyst assessment",
        "region": {
          "offset": 5500,
          "length": 3
        },
        "ttlMs": 300000
