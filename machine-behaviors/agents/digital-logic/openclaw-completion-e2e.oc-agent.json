        "offset": 4210,
        "length": 4
      },
      "semantics": [
        "completed",
        "failed",
        "confidence",
        "actionClass"
      ],
      "ttlMs": 300000,
      "normalization": "already-normalized-0-1",
      "ingest": {
        "endpoint": "/api/integrations/completions",
        "method": "POST",
        "triggerPush": false,
        "compactPush": true
      },
