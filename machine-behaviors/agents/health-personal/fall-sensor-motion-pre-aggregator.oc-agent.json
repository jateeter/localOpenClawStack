        "sensorId": "acp.openclaw.fall_sensor_motion_preaggregator.input-analyst.assessment",
        "name": "OpenClaw fall_sensor_motion_preaggregator input-analyst assessment",
        "region": {
          "offset": 4300,
          "length": 1
        },
        "ttlMs": 300000
      }
    },
    "autonomyPolicy": {
