          "low": "large disparity or excluded population;",
          "mid": "known gap under mitigation;",
          "high": "equitable reach and experience"
        }
      },
      {
        "index": 3,
        "key": "measure_confidence_norm",
        "anchors": {
          "low": "missing/low-quality measures;",
          "mid": "partial indicator confidence;",
          "high": "timely, actionable, trusted measures"
        }
      }
    ],
